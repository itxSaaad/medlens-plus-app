{
  "name": "@medlens/api",
  "private": true,
  "version": "0.1.0",
  "description": "FastAPI backend managed via pnpm scripts and uv",
  "scripts": {
    "dev": "uv run uvicorn src.api.main:app --host 0.0.0.0 --port 8000 --reload",
    "lint": "uv run ruff check .",
    "typecheck": "uv run mypy src",
    "test": "uv run pytest -m \"not integration\"",
    "test:integration": "uv run pytest -m integration --run-integration"
  }
}
