{
  "name": "@medlens/api",
  "private": true,
  "version": "0.1.0",
  "description": "FastAPI backend managed via pnpm scripts and uv",
  "scripts": {
    "dev": "UV_CACHE_DIR=.uv-cache uv run uvicorn src.api.main:app --host 0.0.0.0 --port 8000 --reload",
    "lint": "UV_CACHE_DIR=.uv-cache uv run ruff check .",
    "typecheck": "UV_CACHE_DIR=.uv-cache uv run mypy src",
    "test": "UV_CACHE_DIR=.uv-cache uv run pytest -m 'not integration'",
    "test:integration": "UV_CACHE_DIR=.uv-cache uv run pytest -m integration --run-integration"
  }
}
