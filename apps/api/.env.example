# Runtime
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000

# Provider selection (adapter factory)
AUTH_PROVIDER=supabase
STORAGE_PROVIDER=supabase
DB_PROVIDER=supabase_postgres
OCR_PROVIDER=docling
LLM_PROVIDER=openai

# Infra endpoints
DATABASE_URL=postgresql://medlens:medlens@localhost:5432/medlens
REDIS_URL=redis://localhost:6379/0

# Optional S3-compatible storage (used when STORAGE_PROVIDER=s3)
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET=medlens-reports
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# Feature Flags
FF_ENABLE_OCR_FALLBACK=true
FF_ENABLE_SCHEMA_VALIDATION=true
FF_ENABLE_HISTORICAL_COMPARISON=true
FF_ENABLE_DOCTOR_PACKET_EXPORT=true
FF_REQUIRE_MANUAL_REVIEW_ON_VALIDATION_ERRORS=true
