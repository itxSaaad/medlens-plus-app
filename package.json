{
  "name": "medlens-plus-monorepo",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.25.0",
  "scripts": {
    "lint": "pnpm -r --if-present lint && pnpm lint:md",
    "lint:md": "markdownlint \"**/*.md\" --ignore node_modules --ignore .next",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test && pnpm api:test",
    "test:integration": "pnpm --filter @medlens/web test:integration && pnpm api:test:integration",
    "build": "pnpm -r --if-present build",
    "commitlint": "commitlint --from=HEAD~1 --to=HEAD",
    "api:lint": "cd apps/api && uv run ruff check .",
    "api:typecheck": "cd apps/api && uv run mypy src",
    "api:test": "cd apps/api && uv run pytest -m 'not integration'",
    "api:test:integration": "cd apps/api && uv run pytest -m integration --run-integration",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "husky": "^9.1.7",
    "markdownlint-cli": "^0.45.0"
  }
}
