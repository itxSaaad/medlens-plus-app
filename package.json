{
  "name": "medlens-plus-monorepo",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.25.0",
  "scripts": {
    "lint": "pnpm -r --if-present lint && pnpm lint:md",
    "lint:md": "markdownlint \"**/*.md\" --ignore node_modules --ignore .next --ignore graphify-out",
    "lint:md:fix": "markdownlint \"**/*.md\" --fix --ignore node_modules --ignore .next --ignore graphify-out",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm --filter @medlens/web test:unit && pnpm --filter @medlens/api test",
    "test:integration": "pnpm --filter @medlens/web test:integration && pnpm --filter @medlens/api test:integration",
    "build": "pnpm -r --if-present build",
    "commitlint": "commitlint --from=HEAD~1 --to=HEAD",
    "api:lint": "pnpm --filter @medlens/api lint",
    "api:typecheck": "pnpm --filter @medlens/api typecheck",
    "api:test": "pnpm --filter @medlens/api test",
    "api:test:integration": "pnpm --filter @medlens/api test:integration",
    "release": "semantic-release",
    "graphify:update": "graphify update . --force",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/github": "^11.0.6",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "husky": "^9.1.7",
    "lint-staged": "15.4.3",
    "markdownlint-cli": "^0.48.0",
    "semantic-release": "^24.2.7"
  },
  "lint-staged": {
    "*.md": "markdownlint --fix --ignore node_modules --ignore .next --ignore graphify-out"
  }
}
