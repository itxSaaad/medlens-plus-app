{
  "name": "medlens-plus-monorepo",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.25.0",
  "scripts": {
    "lint": "turbo run lint && pnpm lint:md",
    "format": "prettier --write . && pnpm -r --if-present format && pnpm format:md",
    "format:check": "prettier --check .",
    "format:md": "pnpm lint:md:fix",
    "lint:md": "markdownlint \"**/*.md\" --ignore node_modules --ignore \"**/node_modules/**\" --ignore .next --ignore \"graphify-out/**\" --ignore \".cursor/**\" --ignore \".claude/skills/graphify/**\"",
    "lint:md:fix": "markdownlint \"**/*.md\" --fix --ignore node_modules --ignore \"**/node_modules/**\" --ignore .next --ignore \"graphify-out/**\" --ignore \".cursor/**\" --ignore \".claude/skills/graphify/**\"",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:integration": "turbo run test:integration",
    "build": "turbo run build",
    "commitlint": "commitlint --from=HEAD~1 --to=HEAD",
    "api:lint": "pnpm --filter @medlens/api lint",
    "api:typecheck": "pnpm --filter @medlens/api typecheck",
    "api:test": "pnpm --filter @medlens/api test",
    "api:test:integration": "pnpm --filter @medlens/api test:integration",
    "release": "semantic-release",
    "graphify:update": "graphify update . --force",
    "prepare": "husky",
    "setup": "pnpm install",
    "postinstall": "node scripts/sync-python-deps.mjs"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^19.8.0",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/github": "^12.0.9",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "husky": "^9.1.7",
    "lint-staged": "17.0.8",
    "markdownlint-cli": "^0.49.0",
    "prettier": "^3.9.5",
    "semantic-release": "^25.0.6",
    "turbo": "^2.10.4"
  }
}
